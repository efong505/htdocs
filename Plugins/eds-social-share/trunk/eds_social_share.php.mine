// Settings
function social_share_settings() {
    add_settings_section( 'social_share_config_section', 'Enable/Disable Platforms', null, 'social-share' );

    // Toggle checkboxes
    $platforms = array(
        'facebook'  => 'Facebook',
        'twitter'   => 'X (Twitter)',
        'instagram' => 'Instagram',
        'github'    => 'GitHub',
        'youtube'   => 'YouTube',
        'linkedin'  => 'LinkedIn',
        'pinterest' => 'Pinterest',
        'tiktok'      => 'TikTok',
        'threads'     => 'Threads',
        'whatsapp'    => 'WhatsApp',
        'reddit'      => 'Reddit',
        'telegram'    => 'Telegram',
        'truthsocial' => 'Truth Social',
        'mail'        => 'Email',
        'print'     => 'Print',
    );

    foreach ( $platforms as $key => $label ) {
        $option_name = 'social-share-' . $key;
        add_settings_field( $option_name, $label . ':', 'ess_render_checkbox', 'social-share', 'social_share_config_section', array( 'option' => $option_name ) );
        register_setting( 'social_share_config_section', $option_name, array( 'sanitize_callback' => 'absint' ) );
    }

    // Profile URL section
    add_settings_section( 'social_share_urls_section', 'Profile URLs', 'ess_urls_section_description', 'social-share' );

    $url_fields = array(
        'social-share-twitter-handle'  => 'X (Twitter) Handle (without @)',
        'social-share-instagram-url'   => 'Instagram Profile URL',
        'social-share-github-url'      => 'GitHub Profile URL',
        'social-share-youtube-url'     => 'YouTube Channel URL',
        'social-share-tiktok-url'      => 'TikTok Profile URL',
        'social-share-threads-url'     => 'Threads Profile URL',
    );

    foreach ( $url_fields as $option_name => $label ) {
        add_settings_field( $option_name, $label . ':', 'ess_render_text_field', 'social-share', 'social_share_urls_section', array( 'option' => $option_name ) );
        $sanitize = strpos( $option_name, 'handle' ) !== false ? 'sanitize_text_field' : 'esc_url_raw';
        register_setting( 'social_share_config_section', $option_name, array( 'sanitize_callback' => $sanitize ) );
    }

    // Open Graph section
    add_settings_section( 'social_share_og_section', 'Open Graph / Social Share Image', 'ess_og_section_description', 'social-share' );

    add_settings_field( 'ess-og-enabled', 'Enable Open Graph Tags:', 'ess_render_checkbox', 'social-share', 'social_share_og_section', array( 'option' => 'ess-og-enabled' ) );
    register_setting( 'social_share_config_section', 'ess-og-enabled', array( 'sanitize_callback' => 'absint' ) );

    add_settings_field( 'ess-og-override', 'Override other SEO plugins (Yoast, etc.):', 'ess_render_checkbox', 'social-share', 'social_share_og_section', array( 'option' => 'ess-og-override' ) );
    register_setting( 'social_share_config_section', 'ess-og-override', array( 'sanitize_callback' => 'absint' ) );

    add_settings_field( 'ess-og-default-image', 'Default Share Image (1200×630):', 'ess_render_image_field', 'social-share', 'social_share_og_section', array( 'option' => 'ess-og-default-image' ) );
    register_setting( 'social_share_config_section', 'ess-og-default-image', array( 'sanitize_callback' => 'esc_url_raw' ) );
}

function ess_og_section_description() {
    echo '<p>Control the image, title, and description that appear when your pages are shared on Facebook, LinkedIn, X, and other platforms. If you use Yoast SEO, RankMath, or Jetpack, this feature is automatically disabled to avoid conflicts.</p>';
}

function ess_render_image_field( $args ) {
    $option = $args['option'];
    $value = get_option( $option, '' );
    wp_enqueue_media();
    ?>
    <input type="text" id="<?php echo esc_attr( $option ); ?>" name="<?php echo esc_attr( $option ); ?>" value="<?php echo esc_url( $value ); ?>" style="width:400px;" />
    <button type="button" class="button" onclick="var frame=wp.media({title:'Select Default Share Image',multiple:false});frame.on('select',function(){var url=frame.state().get('selection').first().toJSON().url;document.getElementById('<?php echo esc_attr( $option ); ?>').value=url;document.getElementById('<?php echo esc_attr( $option ); ?>-preview').src=url;document.getElementById('<?php echo esc_attr( $option ); ?>-preview').style.display='block';});frame.open();">Select Image</button>
    <?php if ( $value ) : ?>
        <br><img id="<?php echo esc_attr( $option ); ?>-preview" src="<?php echo esc_url( $value ); ?>" style="max-width:300px;height:auto;margin-top:10px;display:block;" />
    <?php else : ?>
        <br><img id="<?php echo esc_attr( $option ); ?>-preview" src="" style="max-width:300px;height:auto;margin-top:10px;display:none;" />
    <?php endif; ?>
    <p class="description">Recommended: 1200×630 pixels. This image is used when a page doesn't have its own share image or featured image.</p>
    <?php
}

function ess_urls_section_description() {
    echo '<p>For platforms that link to your profile (not share), enter your profile URL below.</p>';
}

function ess_render_checkbox( $args ) {
    $option = $args['option'];
    ?>
    <input type="checkbox" name="<?php echo esc_attr( $option ); ?>" value="1" <?php checked( 1, get_option( $option ), true ); ?> />
    <?php
}

function ess_render_text_field( $args ) {
    $option = $args['option'];
    $value = get_option( $option, '' );
    $placeholder = strpos( $option, 'handle' ) !== false ? 'yourhandle' : 'https://';
    ?>
    <input type="text" name="<?php echo esc_attr( $option ); ?>" value="<?php echo esc_attr( $value ); ?>" placeholder="<?php echo esc_attr( $placeholder ); ?>" style="width:400px;" />
    <?php
}

// Options Page
function esa_options_admin_page() {
    ?>
    <div class="wrap">
        <h1>Social Sharing Options</h1>
        <form method="post" action="options.php">
            <?php
                settings_fields( 'social_share_config_section' );
                do_settings_sections( 'social-share' );
                submit_button();
            ?>
        </form>
    </div>
